# App database URLs.
# In Docker/Portainer, these are normally generated from POSTGRES_* values.
DATABASE_URL=postgresql+asyncpg://mlbapi:change-me@db:5432/mlbapi
DATABASE_URL_SYNC=postgresql+psycopg2://mlbapi:change-me@db:5432/mlbapi

# MLB Stats API
MLB_API_BASE_URL=https://statsapi.mlb.com

# Portainer stack values
POSTGRES_DB=mlbapi
POSTGRES_USER=mlbapi
POSTGRES_PASSWORD=change-me
MLBAPI_IMAGE=ghcr.io/your-github-user/mlbapi:latest
MLBAPI_PORT=8000
TZ=America/Phoenix

# Traefik stack values
MLBAPI_HOST=mlb.api.nawx.app
TRAEFIK_NETWORK=proxy
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt

