# Portainer stack values
MLBAPI_IMAGE=ghcr.io/jnawx/mlbapi:latest
TZ=America/Phoenix

# Existing Postgres container/service on homelab_network.
# POSTGRES_HOST should be the Docker DNS name of the existing Postgres service.
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
POSTGRES_USER=mlbapi
POSTGRES_DB=mlbapi
POSTGRES_PASSWORD=change-me

# Daily sync worker.
DAILY_SYNC_TIME=06:00
SYNC_ON_START=true
SYNC_TARGET_DAYS_AGO=1
SYNC_RETRY_SECONDS=3600

# The stack generates these URLs from the values above.
DATABASE_URL=postgresql+asyncpg://mlbapi:change-me@postgresql:5432/mlbapi
DATABASE_URL_SYNC=postgresql+psycopg2://mlbapi:change-me@postgresql:5432/mlbapi

# MLB Stats API
MLB_API_BASE_URL=https://statsapi.mlb.com
